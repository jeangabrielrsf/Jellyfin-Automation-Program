# Database
DATABASE_URL=postgresql://jfa_user:jfa_password@localhost:5432/jellyfin_automation

# TMDB API (get yours at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# qBittorrent Web UI
QBITTORRENT_HOST=http://localhost:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# Jackett
JACKETT_URL=http://localhost:9117
JACKETT_API_KEY=your_jackett_api_key_here

# Jellyfin
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-in-production

# Library paths (use absolute paths)
MOVIES_PATH=/media/movies
SERIES_PATH=/media/series
ANIMES_PATH=/media/animes

# Default preferences
DEFAULT_QUALITY=1080p
DEFAULT_LANGUAGE=legendado
